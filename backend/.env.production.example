# ── CineMatch Backend — Render Environment Variables ──────────────────────────
# Set these in: Render Dashboard → Your Service → Environment

NODE_ENV=production
PORT=10000

# PostgreSQL — Supabase connection string (Session mode, port 5432)
DATABASE_URL=postgresql://postgres.XXXX:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Redis — Upstash (use TLS URL)
REDIS_URL=rediss://default:PASSWORD@HOSTNAME.upstash.io:PORT

# Auth
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_32_CHARS_MINIMUM
JWT_EXPIRES_IN=7d

# TMDB API
TMDB_API_KEY=your_tmdb_api_key_here

# OpenRouter (Llama 3.3 70B)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Frontend URL for CORS — set to your Vercel deployment URL (no trailing slash)
FRONTEND_URL=https://YOUR-APP-NAME.vercel.app
